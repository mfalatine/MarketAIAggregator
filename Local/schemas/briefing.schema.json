{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "title", "stance", "executive_summary", "findings", "catalysts", "watchlist"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "title": { "type": "string" },
    "stance": { "type": "string" },
    "executive_summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "section", "headline", "summary", "why_it_matters", "claim_type", "confidence", "horizon", "importance", "ticker", "source_urls"],
        "properties": {
          "id": { "type": "string" },
          "section": { "type": "string" },
          "headline": { "type": "string" },
          "summary": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "claim_type": { "type": "string", "enum": ["confirmed", "estimate", "market-implied", "interpretation"] },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "horizon": { "type": "string" },
          "importance": { "type": "string", "enum": ["high", "medium", "low"] },
          "ticker": { "type": "string" },
          "source_urls": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "catalysts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "event", "expectation", "impact", "source_urls"],
        "properties": {
          "date": { "type": "string" },
          "event": { "type": "string" },
          "expectation": { "type": "string" },
          "impact": { "type": "string" },
          "source_urls": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "watchlist": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ticker", "catalyst", "potential_impact", "next_date", "source_urls"],
        "properties": {
          "ticker": { "type": "string" },
          "catalyst": { "type": "string" },
          "potential_impact": { "type": "string" },
          "next_date": { "type": "string" },
          "source_urls": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
